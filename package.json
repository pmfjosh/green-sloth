{
  "name": "greensloth",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write src/",
    "lint": "eslint src/",
    "generate:mxl": "vite-node scripts/generate-mxl.ts",
    "validate:models": "vite-node scripts/validate-models.ts",
    "sync:names": "vite-node scripts/sync-names.ts"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": ">=10.0.0",
    "@sveltejs/adapter-static": ">=3.0.10",
    "@sveltejs/kit": ">=2.65.0",
    "@sveltejs/vite-plugin-svelte": ">=7.2.0",
    "@types/node": "^26.1.1",
    "eslint": ">=10.7.0",
    "eslint-config-prettier": ">=10.0.0",
    "eslint-plugin-svelte": ">=3.20.0",
    "globals": ">=17.7.0",
    "prettier": ">=3.9.5",
    "prettier-plugin-svelte": ">=4.1.1",
    "svelte": ">=5.56.4",
    "svelte-check": ">=4.7.2",
    "typescript": ">=6.0.0",
    "typescript-eslint": ">=8.62.1",
    "vite": ">=8.1.4",
    "vite-node": ">=4.0.0",
    "vite-plugin-wasm": ">=3.3.0"
  },
  "dependencies": {
    "@computational-biology-aachen/design": "github:Computational-Biology-Aachen/design",
    "@computational-biology-aachen/mxlweb-core": "github:Computational-Biology-Aachen/mxlweb-core",
    "@fortawesome/free-brands-svg-icons": ">=7.2.0",
    "@fortawesome/free-solid-svg-icons": ">=7.2.0",
    "@sveltejs/adapter-static": ">=3.0.10",
    "ajv": ">=8.18",
    "chroma-js": "^3.1.2",
    "svelte-exmarkdown": "^5.0.2",
    "wat-compiler": "^1.1.1"
  }
}
