    "@types/papaparse": "^5.5.2",
    "eslint": ">=10.0.0",
    "eslint-config-prettier": ">=10.0.0",
    "eslint-plugin-svelte": ">=3.0.0",
    "globals": ">=17.0.0",
    "prettier": ">=3.0.0",
    "prettier-plugin-svelte": ">=3.0.0",
    "svelte": ">=5.0.0",
    "svelte-check": ">=4.0.0",
    "typescript": ">=6.0.0",
    "typescript-eslint": ">=8.0.0",
    "vite": ">=6.0.0"
  },
  "dependencies": {
    "@computational-biology-aachen/design": "github:Computational-Biology-Aachen/design",
    "@sveltejs/adapter-static": ">=3.0.10",
